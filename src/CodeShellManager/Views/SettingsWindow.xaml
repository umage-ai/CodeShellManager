<Window x:Class="CodeShellManager.Views.SettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Settings" Height="700" Width="600"
        WindowStartupLocation="CenterOwner" ResizeMode="NoResize"
        Background="#1e1e2e" Foreground="#cdd6f4"
        FontFamily="Segoe UI">
    <Window.Resources>
        <Style x:Key="SectionHeader" TargetType="TextBlock">
            <Setter Property="Foreground" Value="#89b4fa"/>
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Margin" Value="0,16,0,8"/>
        </Style>
        <Style x:Key="Label" TargetType="TextBlock">
            <Setter Property="Foreground" Value="#a6adc8"/>
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="Margin" Value="0,0,0,3"/>
        </Style>
        <Style TargetType="TextBox">
            <Setter Property="Background" Value="#313244"/>
            <Setter Property="Foreground" Value="#cdd6f4"/>
            <Setter Property="BorderBrush" Value="#45475a"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="6,4"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="CaretBrush" Value="#cdd6f4"/>
        </Style>
        <Style TargetType="PasswordBox">
            <Setter Property="Background" Value="#313244"/>
            <Setter Property="Foreground" Value="#cdd6f4"/>
            <Setter Property="BorderBrush" Value="#45475a"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="6,4"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="CaretBrush" Value="#cdd6f4"/>
        </Style>
        <Style TargetType="CheckBox">
            <Setter Property="Foreground" Value="#cdd6f4"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Margin" Value="0,0,0,6"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
        </Style>
        <Style x:Key="Btn" TargetType="Button">
            <Setter Property="Background" Value="#313244"/>
            <Setter Property="Foreground" Value="#cdd6f4"/>
            <Setter Property="BorderBrush" Value="#45475a"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="12,6"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#45475a"/>
                </Trigger>
            </Style.Triggers>
        </Style>
        <Style x:Key="PrimaryBtn" TargetType="Button" BasedOn="{StaticResource Btn}">
            <Setter Property="Background" Value="#89b4fa"/>
            <Setter Property="Foreground" Value="#1e1e2e"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#b4d0fb"/>
                </Trigger>
            </Style.Triggers>
        </Style>
        <!-- ComboBox with full dark-theme template (popup inherits system colors without this) -->
        <Style TargetType="ComboBox">
            <Setter Property="Background" Value="#313244"/>
            <Setter Property="Foreground" Value="#cdd6f4"/>
            <Setter Property="BorderBrush" Value="#45475a"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="6,4"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="MaxDropDownHeight" Value="240"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ComboBox">
                        <Grid>
                            <!-- Selection box border -->
                            <Border x:Name="border"
                                    Background="{TemplateBinding Background}"
                                    BorderBrush="{TemplateBinding BorderBrush}"
                                    BorderThickness="{TemplateBinding BorderThickness}"
                                    CornerRadius="2"/>
                            <!-- Selected item text -->
                            <ContentPresenter x:Name="ContentSite"
                                              IsHitTestVisible="False"
                                              Content="{TemplateBinding SelectionBoxItem}"
                                              ContentTemplate="{TemplateBinding SelectionBoxItemTemplate}"
                                              Margin="8,5,28,5"
                                              VerticalAlignment="Center"
                                              TextElement.Foreground="#cdd6f4"/>
                            <!-- Invisible toggle button covers full control -->
                            <ToggleButton Focusable="False" ClickMode="Press"
                                          IsChecked="{Binding IsDropDownOpen, Mode=TwoWay,
                                              RelativeSource={RelativeSource TemplatedParent}}">
                                <ToggleButton.Template>
                                    <ControlTemplate TargetType="ToggleButton">
                                        <Border Background="Transparent"/>
                                    </ControlTemplate>
                                </ToggleButton.Template>
                            </ToggleButton>
                            <!-- Drop arrow -->
                            <TextBlock Text="▾" Foreground="#6c7086" FontSize="11"
                                       HorizontalAlignment="Right" VerticalAlignment="Center"
                                       Margin="0,0,8,0" IsHitTestVisible="False"/>
                            <!-- Dropdown popup -->
                            <Popup x:Name="Popup" Placement="Bottom" Focusable="False"
                                   AllowsTransparency="True" PopupAnimation="Slide"
                                   IsOpen="{TemplateBinding IsDropDownOpen}">
                                <Border Background="#313244" BorderBrush="#45475a" BorderThickness="1"
                                        MinWidth="{Binding ActualWidth,
                                            RelativeSource={RelativeSource AncestorType=ComboBox}}"
                                        MaxHeight="{TemplateBinding MaxDropDownHeight}">
                                    <ScrollViewer SnapsToDevicePixels="True">
                                        <StackPanel IsItemsHost="True"
                                                    KeyboardNavigation.DirectionalNavigation="Contained"/>
                                    </ScrollViewer>
                                </Border>
                            </Popup>
                        </Grid>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="BorderBrush" Value="#6c7086"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style TargetType="ComboBoxItem">
            <Setter Property="Foreground" Value="#cdd6f4"/>
            <Setter Property="Background" Value="#313244"/>
            <Setter Property="Padding" Value="8,5"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ComboBoxItem">
                        <Border x:Name="Bd" Background="{TemplateBinding Background}"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#45475a"/>
                            </Trigger>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#585b70"/>
                            </Trigger>
                            <Trigger Property="IsHighlighted" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#45475a"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Scrollable settings area -->
        <ScrollViewer Grid.Row="0" VerticalScrollBarVisibility="Auto"
                      Padding="24,16,24,8">
            <StackPanel>

                <!-- Session Settings -->
                <TextBlock Text="SESSION SETTINGS" Style="{StaticResource SectionHeader}"
                           Margin="0,0,0,8"/>
                <Border BorderBrush="#313244" BorderThickness="0,0,0,1" Margin="0,4,0,0"/>

                <StackPanel Margin="0,8,0,0">
                    <TextBlock Text="Default Working Folder" Style="{StaticResource Label}"/>
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBox x:Name="DefaultFolderBox" Grid.Column="0" Margin="0,0,6,0"/>
                        <Button Grid.Column="1" Content="Browse…" Style="{StaticResource Btn}"
                                Padding="10,5" FontSize="12"
                                Click="BrowseFolderButton_Click"/>
                    </Grid>
                </StackPanel>

                <StackPanel Margin="0,10,0,0">
                    <TextBlock Text="Default Command" Style="{StaticResource Label}"/>
                    <ComboBox x:Name="DefaultCommandCombo">
                        <ComboBoxItem Content="claude" Tag="claude"/>
                        <ComboBoxItem Content="claude --continue" Tag="claude --continue"/>
                        <ComboBoxItem Content="claude --model claude-opus-4-6" Tag="claude --model claude-opus-4-6"/>
                        <ComboBoxItem Content="claude --dangerously-skip-permissions" Tag="claude --dangerously-skip-permissions"/>
                        <ComboBoxItem Content="codex" Tag="codex"/>
                        <ComboBoxItem Content="gh copilot suggest" Tag="gh copilot suggest"/>
                        <ComboBoxItem Content="pwsh" Tag="pwsh"/>
                        <ComboBoxItem Content="cmd" Tag="cmd"/>
                    </ComboBox>
                </StackPanel>

                <CheckBox x:Name="AutoRestoreCheck" Content="Auto-restore sessions on startup"
                          Margin="0,12,0,0"/>

                <!-- Appearance -->
                <TextBlock Text="APPEARANCE" Style="{StaticResource SectionHeader}"/>
                <Border BorderBrush="#313244" BorderThickness="0,0,0,1" Margin="0,4,0,0"/>

                <StackPanel Margin="0,8,0,0">
                    <CheckBox x:Name="ShowGitBranchCheck" Content="Show git branch in sidebar"/>
                    <CheckBox x:Name="ShowTerminalStatusDotCheck" Content="Show terminal status indicator"/>
                </StackPanel>

                <!-- Terminal -->
                <TextBlock Text="TERMINAL" Style="{StaticResource SectionHeader}"/>
                <Border BorderBrush="#313244" BorderThickness="0,0,0,1" Margin="0,4,0,0"/>

                <StackPanel Margin="0,8,0,0">
                    <TextBlock Text="Font Family" Style="{StaticResource Label}"/>
                    <TextBox x:Name="FontFamilyBox"/>

                    <Grid Margin="0,8,0,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="16"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0">
                            <TextBlock Text="Font Size" Style="{StaticResource Label}"/>
                            <TextBox x:Name="FontSizeBox"/>
                        </StackPanel>
                        <StackPanel Grid.Column="2">
                            <TextBlock Text="Font Weight" Style="{StaticResource Label}"/>
                            <ComboBox x:Name="FontWeightCombo">
                                <ComboBoxItem Content="normal" Tag="normal"/>
                                <ComboBoxItem Content="bold" Tag="bold"/>
                                <ComboBoxItem Content="100" Tag="100"/>
                                <ComboBoxItem Content="200" Tag="200"/>
                                <ComboBoxItem Content="300" Tag="300"/>
                                <ComboBoxItem Content="400" Tag="400"/>
                                <ComboBoxItem Content="500" Tag="500"/>
                                <ComboBoxItem Content="600" Tag="600"/>
                                <ComboBoxItem Content="700" Tag="700"/>
                            </ComboBox>
                        </StackPanel>
                    </Grid>

                    <Grid Margin="0,8,0,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="16"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0">
                            <TextBlock Text="Letter Spacing (px)" Style="{StaticResource Label}"/>
                            <TextBox x:Name="LetterSpacingBox"/>
                        </StackPanel>
                        <StackPanel Grid.Column="2">
                            <TextBlock Text="Line Height" Style="{StaticResource Label}"/>
                            <TextBox x:Name="LineHeightBox"/>
                        </StackPanel>
                    </Grid>

                    <CheckBox x:Name="FontLigaturesCheck" Content="Enable font ligatures"
                              Margin="0,10,0,0"/>
                </StackPanel>

                <!-- Notifications -->
                <TextBlock Text="NOTIFICATIONS" Style="{StaticResource SectionHeader}"/>
                <Border BorderBrush="#313244" BorderThickness="0,0,0,1" Margin="0,4,0,0"/>

                <StackPanel Margin="0,8,0,0">
                    <CheckBox x:Name="ShowToastCheck" Content="Show toast notifications"/>
                </StackPanel>

                <!-- Search -->
                <TextBlock Text="SEARCH" Style="{StaticResource SectionHeader}"/>
                <Border BorderBrush="#313244" BorderThickness="0,0,0,1" Margin="0,4,0,0"/>

                <StackPanel Margin="0,8,0,0">
                    <TextBlock Text="Max Search Results" Style="{StaticResource Label}"/>
                    <TextBox x:Name="MaxSearchResultsBox" Width="100" HorizontalAlignment="Left"/>
                    <CheckBox x:Name="SearchCollapseAfterNavigateCheck"
                              Content="Auto-close search after navigating to result"
                              Margin="0,10,0,0"/>
                </StackPanel>

                <!-- Launch Commands -->
                <TextBlock Text="LAUNCH COMMANDS" Style="{StaticResource SectionHeader}"/>
                <Border BorderBrush="#313244" BorderThickness="0,0,0,1" Margin="0,4,0,0"/>

                <StackPanel Margin="0,8,0,0">
                    <TextBlock Text="One command per line — each becomes an option in the New Session dialog."
                               Foreground="#6c7086" FontSize="10" Margin="0,0,0,6" TextWrapping="Wrap"/>
                    <TextBox x:Name="LaunchCommandsBox"
                             AcceptsReturn="True" AcceptsTab="False"
                             Height="120" VerticalScrollBarVisibility="Auto"
                             VerticalContentAlignment="Top"
                             FontFamily="Consolas" FontSize="12"/>
                </StackPanel>

                <!-- API -->
                <TextBlock Text="API" Style="{StaticResource SectionHeader}"/>
                <Border BorderBrush="#313244" BorderThickness="0,0,0,1" Margin="0,4,0,0"/>

                <StackPanel Margin="0,8,0,16">
                    <TextBlock Text="Anthropic API Key" Style="{StaticResource Label}"/>
                    <PasswordBox x:Name="ApiKeyBox"/>
                    <TextBlock Text="Stored locally. Used for future integrations."
                               Foreground="#6c7086" FontSize="10" Margin="0,4,0,0"/>
                </StackPanel>

            </StackPanel>
        </ScrollViewer>

        <!-- Bottom button bar -->
        <Border Grid.Row="1" Background="#181825" BorderThickness="0,1,0,0"
                BorderBrush="#313244" Padding="24,12">
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                <Button Content="Cancel" Style="{StaticResource Btn}" Margin="0,0,8,0"
                        Click="Cancel_Click"/>
                <Button Content="Save" Style="{StaticResource PrimaryBtn}" Click="Save_Click"
                        IsDefault="True"/>
            </StackPanel>
        </Border>
    </Grid>
</Window>
