                            </Path>
                            <!-- "ai" — brand gold -->
                            <Path Fill="#b8966a">
                                <Path.RenderTransform>
                                    <TranslateTransform X="-28.797913" Y="-73.041197"/>
                                </Path.RenderTransform>
                                <Path.Data>M166.58964 130.12094c-2.77707.0-5.04613-.7112-6.8072-2.1336-1.7272-1.4224-2.5908-3.26813-2.5908-5.5372.0-2.40453.9144-4.30107 2.7432-5.6896s4.30107-2.0828 7.4168-2.0828c2.7432.0 5.2324.57573 7.4676 1.7272v-3.3528c0-4.09787-2.25213-6.1468-6.7564-6.1468-1.25307.0-2.52307.18627-3.81.5588-1.25307.33867-2.6416.89747-4.1656 1.6764l-1.4224-2.8956c1.8288-.88053 3.52213-1.524 5.08-1.9304s3.11573-.6096 4.6736-.6096c3.21733.0 5.6896.762 7.4168 2.286 1.76107 1.524 2.6416 3.7084 2.6416 6.5532v17.1196h-3.6576v-2.4892c-2.26907 1.96427-5.01227 2.9464-8.2296 2.9464zm-5.7912-7.7724c0 1.4224.59267 2.5908 1.778 3.5052 1.2192.88053 2.77707 1.3208 4.6736 1.3208 3.08187.0 5.60493-.98213 7.5692-2.9464v-4.7752c-1.99813-1.35467-4.45347-2.032-7.366-2.032-2.032.0-3.6576.4572-4.8768 1.3716-1.18533.88053-1.778 2.06587-1.778 3.556zm23.97764 7.3152v-25.4508h3.7592v25.4508z</Path.Data>
                            </Path>
                        </Canvas>
                    </Viewbox>
                </StackPanel>

                <!-- Links -->
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,6,0,0">
                    <TextBlock FontSize="11" FontFamily="Segoe UI">
                        <Hyperlink NavigateUri="https://umage.ai"
                                   RequestNavigate="Hyperlink_RequestNavigate"
                                   Foreground="#585b70" TextDecorations="None">
                            umage.ai
                        </Hyperlink>
                    </TextBlock>
                    <TextBlock Text=" · " Foreground="#45475a" FontSize="11" FontFamily="Segoe UI"
                               VerticalAlignment="Center"/>
                    <TextBlock FontSize="11" FontFamily="Segoe UI">
                        <Hyperlink NavigateUri="https://github.com/umage-ai/CodeShellManager"
                                   RequestNavigate="Hyperlink_RequestNavigate"
                                   Foreground="#585b70" TextDecorations="None">
                            GitHub
                        </Hyperlink>
                    </TextBlock>
                </StackPanel>

                <!-- Close button -->
                <Button Content="Close" HorizontalAlignment="Center"
                        Margin="0,18,0,0" Padding="28,7" FontSize="12" Cursor="Hand"
                        FontFamily="Segoe UI" Foreground="#cdd6f4"
                        Click="Close_Click">
                    <Button.Template>
                        <ControlTemplate TargetType="Button">
                            <Border x:Name="Bd" Background="#313244" BorderBrush="#45475a"
                                    BorderThickness="1" CornerRadius="5"
                                    Padding="{TemplateBinding Padding}">
                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter TargetName="Bd" Property="Background" Value="#45475a"/>
                                </Trigger>
                                <Trigger Property="IsPressed" Value="True">
                                    <Setter TargetName="Bd" Property="Background" Value="#585b70"/>
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Button.Template>
                </Button>

            </StackPanel>
        </DockPanel>
    </Border>
</Window>
