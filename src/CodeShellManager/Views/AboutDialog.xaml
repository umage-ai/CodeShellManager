<Window x:Class="CodeShellManager.Views.AboutDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="About CodeShellManager" Height="290" Width="400"
        WindowStyle="None" AllowsTransparency="True" Background="Transparent"
        WindowStartupLocation="CenterOwner" ResizeMode="NoResize">

    <!-- Outer rounded card -->
    <Border Background="#1e1e2e" BorderBrush="#45475a" BorderThickness="1"
            CornerRadius="10" Effect="{x:Null}">
        <DockPanel>

            <!-- ── Custom title bar ── -->
            <Border DockPanel.Dock="Top" Background="#181825" CornerRadius="10,10,0,0"
                    Padding="14,8,10,8" MouseLeftButtonDown="TitleBar_Drag">
                <DockPanel>
                    <Button DockPanel.Dock="Right" Content="✕" Width="24" Height="24"
                            Background="Transparent" BorderThickness="0"
                            Foreground="#6c7086" FontSize="12" Cursor="Hand"
                            Click="Close_Click">
                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <Border x:Name="Bd" Background="Transparent" CornerRadius="4"
                                        Width="24" Height="24">
                                    <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Border>
                                <ControlTemplate.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter TargetName="Bd" Property="Background" Value="#f38ba820"/>
                                        <Setter Property="Foreground" Value="#f38ba8"/>
                                    </Trigger>
                                </ControlTemplate.Triggers>
                            </ControlTemplate>
                        </Button.Template>
                    </Button>
                    <TextBlock Text="About" Foreground="#6c7086" FontSize="11"
                               VerticalAlignment="Center" FontFamily="Segoe UI"/>
                </DockPanel>
            </Border>

            <!-- ── Content ── -->
            <StackPanel Margin="0,20,0,24" HorizontalAlignment="Center">

                <!-- Terminal >_ icon -->
                <Border Width="48" Height="48" CornerRadius="10" HorizontalAlignment="Center"
                        Background="#11111b" BorderBrush="#313244" BorderThickness="1"
                        Margin="0,0,0,14">
                    <Canvas Width="32" Height="32" HorizontalAlignment="Center" VerticalAlignment="Center">
                        <Path Canvas.Left="0" Canvas.Top="0"
                              Data="M 6,9 L 14,16 L 6,23"
                              Stroke="#89b4fa" StrokeThickness="2.5"
                              StrokeLineJoin="Round" StrokeStartLineCap="Round" StrokeEndLineCap="Round"/>
                        <Rectangle Canvas.Left="16" Canvas.Top="21.75" Width="12" Height="2.5" Fill="#a6e3a1"/>
                    </Canvas>
                </Border>

                <!-- App name -->
                <TextBlock Text="CodeShellManager" FontSize="20" FontWeight="Bold"
                           Foreground="#cdd6f4" HorizontalAlignment="Center" FontFamily="Segoe UI"
                           Margin="0,0,0,4"/>
                <TextBlock Text="Multi-terminal host for Claude Code &amp; friends"
                           FontSize="11" Foreground="#6c7086" HorizontalAlignment="Center"
                           FontFamily="Segoe UI" Margin="0,0,0,2"/>
                <TextBlock Text="Version 1.0.0" FontSize="10" Foreground="#45475a"
                           HorizontalAlignment="Center" FontFamily="Segoe UI" Margin="0,0,0,16"/>

                <!-- Separator -->
                <Border Height="1" Background="#313244" Width="260" Margin="0,0,0,14"/>

                <!-- umage.ai logo — "umage." in muted, ".ai" in brand gold -->
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,0,0,4">
                    <TextBlock Text="By " FontSize="11" Foreground="#6c7086"
                               VerticalAlignment="Center" FontFamily="Segoe UI"/>
                    <!-- umage.ai wordmark via SVG paths scaled via Viewbox -->
                    <Viewbox Width="62" Height="20" VerticalAlignment="Center">
                        <Canvas Width="160.477" Height="57.08">
                            <!-- "umage." — light foreground -->
                            <Path Fill="#a6adc8">
                                <Path.RenderTransform>
                                    <TranslateTransform X="-28.797913" Y="-73.041197"/>
                                </Path.RenderTransform>
