<Window x:Class="CodeShellManager.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="CodeShellManager" Height="800" Width="1280" MinWidth="800" MinHeight="500"
        Background="#1e1e2e" Foreground="#cdd6f4"
        FontFamily="Segoe UI"
        WindowState="Maximized"
        Icon="{StaticResource AppIconImage}">

    <Window.Resources>
        <Style x:Key="ToolBtn" TargetType="Button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="#a6adc8"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="8,4"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="FontFamily" Value="Segoe UI"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                Padding="{TemplateBinding Padding}"
                                CornerRadius="4">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#313244"/>
                                <Setter Property="Foreground" Value="#cdd6f4"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter Property="Background" Value="#45475a"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Clickable search result item style -->
        <Style x:Key="SearchResultBtn" TargetType="Button">
            <Setter Property="Background" Value="#1e1e2e"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd" Background="{TemplateBinding Background}"
                                Margin="0,2" Padding="6,4" CornerRadius="4">
                            <ContentPresenter/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#313244"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#45475a"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Grid>
    <DockPanel>
        <!-- ── Top toolbar ─────────────────────────────────────────────── -->
        <Border DockPanel.Dock="Top" Background="#181825" BorderThickness="0,0,0,1"
                BorderBrush="#313244" Padding="8,5">
            <DockPanel>
                <StackPanel DockPanel.Dock="Left" Orientation="Horizontal" VerticalAlignment="Center"
                            Margin="4,0,16,0">
                    <TextBlock Text="CodeShellManager" FontSize="13"
                               FontWeight="SemiBold" Foreground="#cdd6f4" VerticalAlignment="Center"/>
                    <TextBlock Text=" by " FontSize="11" Foreground="#6c7086" VerticalAlignment="Center"/>
                    <TextBlock Text="umage.ai" FontSize="11" FontWeight="SemiBold"
                               Foreground="#89b4fa" VerticalAlignment="Center"
                               Cursor="Hand" ToolTip="https://umage.ai"/>
                    <Button Content="⬆ Export" Style="{StaticResource ToolBtn}"
                            Foreground="#a6adc8" Margin="12,0,2,0"
                            ToolTip="Export current setup to a .csm backup file"
                            Click="Export_Click"/>
                    <Button Content="⬇ Import" Style="{StaticResource ToolBtn}"
                            Foreground="#a6adc8" Margin="2,0,0,0"
                            ToolTip="Import a .csm backup file to restore a setup"
                            Click="Import_Click"/>
                </StackPanel>

                <StackPanel DockPanel.Dock="Right" Orientation="Horizontal" VerticalAlignment="Center">
                    <!-- Update-available badge (shown when a new GitHub release exists) -->
                    <Border x:Name="UpdateBadge" Background="#a6e3a1" CornerRadius="10"
                            Margin="0,0,8,0" VerticalAlignment="Center" Visibility="Collapsed">
                        <DockPanel>
                            <Button DockPanel.Dock="Right" Content="✕"
                                    Background="Transparent" BorderThickness="0"
                                    Foreground="#1e1e2e" FontSize="9" Padding="5,2,5,2"
                                    Cursor="Hand" ToolTip="Dismiss"
                                    Click="UpdateBadgeDismiss_Click"/>
                            <TextBlock x:Name="UpdateBadgeText" Text="↑ update"
                                       Foreground="#1e1e2e" FontSize="11" FontWeight="Bold"
                                       Padding="8,2,2,2" Cursor="Hand" VerticalAlignment="Center"
                                       MouseLeftButtonDown="UpdateBadge_Click"
                                       ToolTip="Click to open release page"/>
                        </DockPanel>
                    </Border>

                    <Border x:Name="AlertBadge" AutomationProperties.AutomationId="AlertBadge" Background="#f38ba8" CornerRadius="10"
                            Padding="7,2" Margin="0,0,8,0" VerticalAlignment="Center"
                            Visibility="Collapsed">
                        <TextBlock x:Name="AlertCountText" Text="!" Foreground="#1e1e2e"
                                   FontSize="11" FontWeight="Bold"/>
                    </Border>
                    <Button x:Name="SearchBtn" AutomationProperties.AutomationId="SearchBtn" Content="⌕ Search" Style="{StaticResource ToolBtn}"
                            Click="ToggleSearch_Click" Margin="0,0,2,0"/>
                    <Button x:Name="CmdHelperBtn" Content="⚡ Commands" Style="{StaticResource ToolBtn}"
                            Click="ToggleCommandHelper_Click" Margin="0,0,4,0"/>
                    <Button x:Name="SettingsButton" AutomationProperties.AutomationId="SettingsBtn" Content="⚙ Settings" Style="{StaticResource ToolBtn}"
                            Click="SettingsButton_Click" Margin="0,0,2,0"/>
                    <Button Content="?" Style="{StaticResource ToolBtn}" ToolTip="About CodeShellManager"
                            Click="AboutButton_Click" Margin="0,0,8,0" Width="26"/>
                    <Button AutomationProperties.AutomationId="Layout_Single" Content="▣" Style="{StaticResource ToolBtn}" ToolTip="Single pane"
                            Click="Layout_Single_Click" Width="26"/>
                    <Button AutomationProperties.AutomationId="Layout_Two" Content="▥" Style="{StaticResource ToolBtn}" ToolTip="2 columns"
                            Click="Layout_Two_Click" Width="26"/>
                    <Button Content="▦" Style="{StaticResource ToolBtn}" ToolTip="3 columns"
                            Click="Layout_Three_Click" Width="26"/>
                    <Button AutomationProperties.AutomationId="Layout_Grid" Content="⊞" Style="{StaticResource ToolBtn}" ToolTip="2×2 grid"
                            Click="Layout_Grid_Click" Width="26"/>
                    <Button Content="⇔" Style="{StaticResource ToolBtn}" ToolTip="2 rows (horizontal split)"
                            Click="Layout_TwoRow_Click" Width="26"/>
                    <Button Content="4" Style="{StaticResource ToolBtn}" ToolTip="4 columns"
                            Click="Layout_Four_Click" Width="26" FontSize="10"/>
                    <Button Content="6" Style="{StaticResource ToolBtn}" ToolTip="6 columns"
                            Click="Layout_Six_Click" Width="26" FontSize="10"/>
                    <Button Content="6×2" Style="{StaticResource ToolBtn}" ToolTip="6×2 grid (12 panes)"
                            Click="Layout_SixTwo_Click" FontSize="9" Padding="4,4"/>
                    <Button Content="6×3" Style="{StaticResource ToolBtn}" ToolTip="6×3 grid (18 panes)"
                            Click="Layout_SixThree_Click" FontSize="9" Padding="4,4"/>
                </StackPanel>

                <Button DockPanel.Dock="Left" AutomationProperties.AutomationId="NewSessionBtn" Content="＋ New Session" Style="{StaticResource ToolBtn}"
                        Foreground="#a6e3a1" Click="NewSession_Click" Margin="0,0,4,0"/>
                <Button DockPanel.Dock="Left" AutomationProperties.AutomationId="BroadcastBtn" Content="⊕ RC All" Style="{StaticResource ToolBtn}"
                        Foreground="#89b4fa" Click="BroadcastRemoteControl_Click" Margin="0,0,4,0"
                        ToolTip="Send /remote-control to all sessions"/>
            </DockPanel>
        </Border>

        <!-- ── Command helper panel ─────────────────────────────────────── -->
        <Border x:Name="CommandHelperPanel" DockPanel.Dock="Top" Background="#11111b"
                BorderThickness="0,0,0,1" BorderBrush="#313244"
                Padding="10,8" Visibility="Collapsed">
            <StackPanel>
                <TextBlock Text="Click to send to active terminal" Foreground="#6c7086"
                           FontSize="10" Margin="0,0,0,6"/>
                <WrapPanel x:Name="ShortcutPanel"/>
            </StackPanel>
        </Border>

        <!-- ── Search panel ─────────────────────────────────────────────── -->
        <Border x:Name="SearchPanelHost" DockPanel.Dock="Top" Background="#11111b"
                BorderThickness="0,0,0,1" BorderBrush="#313244"
                Padding="10,8" MaxHeight="260" Visibility="Collapsed">
            <DockPanel>
                <StackPanel DockPanel.Dock="Left" Width="280" Margin="0,0,12,0">
                    <!-- Header with label and close button -->
                    <DockPanel Margin="0,0,0,6">
                        <Button DockPanel.Dock="Right" Content="✕" x:Name="CloseSearchButton"
                                Background="Transparent" BorderThickness="0"
                                Foreground="#6c7086" FontSize="11" Padding="4,1"
                                Cursor="Hand" ToolTip="Close search (Esc)"
                                Click="CloseSearchButton_Click"/>
                        <TextBlock Text="Search all session output" Foreground="#6c7086"
                                   FontSize="10" VerticalAlignment="Center"/>
                    </DockPanel>
                    <DockPanel>
                        <Button DockPanel.Dock="Right" Content="Go" Margin="6,0,0,0"
                                Background="#89b4fa" Foreground="#1e1e2e"
                                BorderThickness="0" Padding="10,5" Cursor="Hand"
                                Click="Search_Click"/>
                        <TextBox x:Name="SearchBox" Background="#313244" Foreground="#cdd6f4"
                                 BorderBrush="#45475a" Padding="6,5" FontSize="13"
                                 KeyDown="SearchBox_KeyDown"/>
                    </DockPanel>
                </StackPanel>
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <ItemsControl x:Name="SearchResults">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Button Style="{StaticResource SearchResultBtn}"
                                        Click="SearchResult_Click">
                                    <StackPanel>
                                        <DockPanel>
                                            <TextBlock Text="{Binding SessionName}"
                                                       Foreground="#89b4fa" FontSize="11"
                                                       FontWeight="SemiBold"/>
                                            <!-- Note badge — shown only for note results -->
                                            <Border x:Name="NoteBadge" Background="#313244"
                                                    BorderBrush="#a6e3a1" BorderThickness="1"
                                                    CornerRadius="3" Padding="4,1,4,1"
                                                    Margin="5,0,4,0" VerticalAlignment="Center"
                                                    Visibility="Collapsed">
                                                <TextBlock Text="note" Foreground="#a6e3a1" FontSize="9"
                                                           FontWeight="SemiBold"/>
                                            </Border>
                                            <TextBlock Text="{Binding Timestamp, StringFormat='{}{0:HH:mm:ss}'}"
                                                       Foreground="#6c7086" FontSize="10"
                                                       HorizontalAlignment="Right"/>
                                        </DockPanel>
                                        <TextBlock Text="{Binding Snippet}" Foreground="#cdd6f4"
                                                   FontSize="12" FontFamily="Consolas"
                                                   TextWrapping="Wrap" Margin="0,2,0,0"/>
                                    </StackPanel>
                                </Button>
                                <DataTemplate.Triggers>
                                    <DataTrigger Binding="{Binding IsNote}" Value="True">
                                        <Setter TargetName="NoteBadge" Property="Visibility" Value="Visible"/>
                                    </DataTrigger>
                                </DataTemplate.Triggers>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </ScrollViewer>
            </DockPanel>
        </Border>

        <!-- ── Sidebar ──────────────────────────────────────────────────── -->
        <Border DockPanel.Dock="Left" Background="#181825"
                BorderThickness="0,0,1,0" BorderBrush="#313244">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition x:Name="GroupStripCol" Width="0"/>
                    <ColumnDefinition Width="230"/>
                </Grid.ColumnDefinitions>

                <!-- Group tab strip (vertical column of category tabs).
                     Hidden by default; MainWindow toggles GroupStripCol width on/off. -->
                <Border Grid.Column="0" x:Name="GroupStripBorder"
                        Background="#11111b" BorderThickness="0,0,1,0"
                        BorderBrush="#313244" Visibility="Collapsed">
                    <ScrollViewer VerticalScrollBarVisibility="Auto"
                                  HorizontalScrollBarVisibility="Disabled">
                        <StackPanel x:Name="GroupStripPanel"
                                    AutomationProperties.AutomationId="GroupStripPanel"
                                    Margin="0,6,0,6"/>
                    </ScrollViewer>
                </Border>

                <DockPanel Grid.Column="1">
                    <Border x:Name="SidebarHeader" DockPanel.Dock="Top" Padding="12,8,8,8" BorderThickness="0,0,0,1"
                            BorderBrush="#313244" Background="#181825">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="SESSIONS" Foreground="#6c7086" FontSize="10"
                                       FontWeight="Bold" VerticalAlignment="Center"/>
                            <Button Grid.Column="1" x:Name="SortSessionsButton" Content="⇅" Style="{StaticResource ToolBtn}"
                                    ToolTip="Sort sessions" Click="SortSessionsButton_Click"
                                    Width="26" Height="24" FontSize="13" Foreground="#cdd6f4"
                                    VerticalAlignment="Center" Margin="0,0,2,0"
                                    Padding="0,0,0,1"/>
                            <Button Grid.Column="2" Content="+" Style="{StaticResource ToolBtn}"
                                    ToolTip="New Session (Ctrl+T)" Click="NewSession_Click"
                                    Width="26" Height="24" FontSize="16" Foreground="#a6e3a1"
                                    VerticalAlignment="Center" Margin="0,0,2,0"
                                    Padding="0,0,0,2"/>
                        </Grid>
                    </Border>
                    <ScrollViewer VerticalScrollBarVisibility="Auto">
                        <StackPanel x:Name="SidebarSessionList" AutomationProperties.AutomationId="SidebarSessionList" Margin="6,6" Background="Transparent"/>
                    </ScrollViewer>
                </DockPanel>
            </Grid>
        </Border>

        <!-- ── Terminal grid ────────────────────────────────────────────── -->
        <Grid x:Name="TerminalGrid" AutomationProperties.AutomationId="TerminalGrid" Background="#1e1e2e">
            <TextBlock x:Name="EmptyState"
                       Text="No sessions open.&#x0a;Press Ctrl+T or click ＋ New Session to get started."
                       HorizontalAlignment="Center" VerticalAlignment="Center"
                       Foreground="#45475a" FontSize="15" TextAlignment="Center"
                       LineHeight="24"/>
        </Grid>
    </DockPanel>

        <Grid x:Name="ShutdownOverlay" Visibility="Collapsed" Background="#cc1e1e2e" Panel.ZIndex="100">
            <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center" Orientation="Vertical">
                <Grid Width="48" Height="48">
                    <Path Stroke="#89b4fa" StrokeThickness="4" StrokeStartLineCap="Round" StrokeEndLineCap="Round"
                          Data="M 24 4 A 20 20 0 1 1 4 24"
                          RenderTransformOrigin="0.5,0.5">
                        <Path.RenderTransform>
                            <RotateTransform x:Name="ShutdownSpinnerRotate" Angle="0"/>
                        </Path.RenderTransform>
                        <Path.Triggers>
                            <EventTrigger RoutedEvent="Path.Loaded">
                                <BeginStoryboard>
                                    <Storyboard RepeatBehavior="Forever">
                                        <DoubleAnimation Storyboard.TargetName="ShutdownSpinnerRotate"
                                                         Storyboard.TargetProperty="Angle"
                                                         From="0" To="360" Duration="0:0:1.2"/>
                                    </Storyboard>
                                </BeginStoryboard>
                            </EventTrigger>
                        </Path.Triggers>
                    </Path>
                </Grid>
                <TextBlock Text="Shutting down…" Foreground="#cdd6f4" FontFamily="Segoe UI" FontSize="13"
                           Margin="0,14,0,0" HorizontalAlignment="Center"/>
            </StackPanel>
        </Grid>
    </Grid>
</Window>
